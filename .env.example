# --- Local development (Node.js) ---

# Random string, min. 32 characters
SESSION_SECRET=change-me-to-a-long-random-secret

# Set once, then run: npm run admin:init
# Stored only as bcrypt hash in data/cms/.admin-hash
ADMIN_PASSWORD=your-secure-password-here

# Public site URL (metadata, sitemap, Open Graph)
# NEXT_PUBLIC_SITE_URL=https://your-domain.example

# --- Coolify / Docker ---
# PORT=3000
# HOSTNAME=0.0.0.0

# Dočasný landing místo podstránek (vypnuto ve výchozím stavu)
# NEXT_PUBLIC_SUBPAGES_LANDING=1
