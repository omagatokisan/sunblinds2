{
  "name": "sunblinds-web",
  "version": "1.0.0",
  "private": false,
  "type": "module",
  "scripts": {
    "dev": "node scripts/generate-search-index.mjs && node scripts/ensure-reviews-store.mjs && next dev",
    "build": "node scripts/generate-search-index.mjs && node scripts/ensure-reviews-store.mjs && next build",
    "build:ftp": "node scripts/build-ftp-deploy.mjs",
    "start": "next start",
    "lint": "next lint",
    "admin:init": "node scripts/init-admin.mjs",
    "extract-catalog": "node scripts/extract-catalog.mjs",
    "enrich-products": "node scripts/enrich-products.mjs",
